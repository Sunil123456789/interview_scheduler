# Django core
SECRET_KEY=replace-with-strong-secret
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://app.your-domain.com
