# Django core
SECRET_KEY=replace-with-strong-secret
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
OAUTHLIB_INSECURE_TRANSPORT=0

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://app.your-domain.com
CSRF_TRUSTED_ORIGINS=https://app.your-domain.com

# Optional infrastructure
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Google OAuth (token onboarding)
GOOGLE_OAUTH_CLIENT_SECRETS_FILE=client_secrets.json
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/
GOOGLE_OAUTH_SUCCESS_REDIRECT=http://localhost:5173/admin?oauth=success
GOOGLE_OAUTH_FAILURE_REDIRECT=http://localhost:5173/admin?oauth=error
GOOGLE_OAUTH_STATE_MAX_AGE_SECONDS=600

# Google Calendar API credentials (used for refresh/token-based calls)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
